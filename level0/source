#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/types.h>

int main(int ac, char **av) {
    if (atoi(av[1]) != 423) {
        fwrite("No !\n", 1, 5, stderr);
    } else {
        char *args[] = { strdup("/bin/sh"), NULL };
        setresgid(getegid(), getegid(), getegid());
        setresuid(geteuid(), geteuid(), geteuid());
        execv("/bin/sh", args);
    }
    return 0;
}
